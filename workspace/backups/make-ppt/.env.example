# Mission Control MVP flags
# Keep readonly true until explicit live-mode validation is complete.
GATEWAY_URL=ws://127.0.0.1:18789
# Optional path overrides when your OpenClaw/Codex data is not in the default home locations.
# OPENCLAW_HOME=/path/to/.openclaw
# OPENCLAW_CONFIG_PATH=/path/to/openclaw.json
# OPENCLAW_WORKSPACE_ROOT=/path/to/workspace
# OPENCLAW_AGENT_ROOT=/path/to/one/agent/workspace
# CODEX_HOME=/path/to/.codex
# OPENCLAW_SUBSCRIPTION_SNAPSHOT_PATH=/path/to/subscription.json
READONLY_MODE=true
APPROVAL_ACTIONS_ENABLED=false
APPROVAL_ACTIONS_DRY_RUN=true
IMPORT_MUTATION_ENABLED=false
IMPORT_MUTATION_DRY_RUN=false
LOCAL_TOKEN_AUTH_REQUIRED=true
# LOCAL_API_TOKEN=<set-explicitly-for-protected-routes>
MONITOR_CONTINUOUS=false
UI_MODE=false
UI_PORT=4310
# Optional only when a reverse proxy, container, or another machine must reach the UI.
# Keep the default localhost bind for same-machine local-only use.
# UI_BIND_ADDRESS=0.0.0.0

# App Factory provider
# When PLUS_AI_API_KEY is set, the Word -> PPT page will switch to Plus AI templates and generation.
# PLUS_AI_API_KEY=<your-plus-ai-api-key>
# PLUS_AI_API_BASE_URL=https://api.plusdocs.com/r/v0
# PLUS_AI_POLL_TIMEOUT_MS=480000
# PLUS_AI_POLL_INTERVAL_MS=5000

# Image PPT provider
# The image-based PPT demo keeps Chinese text locally rendered for accuracy.
# Gemini/Nano Banana is optional and should be used for text-free illustration backdrops only.
# IMAGE_PPT_PROVIDER=local
# GEMINI_API_KEY=<your-gemini-api-key>
# GOOGLE_API_KEY=<alternative-google-api-key-env>
# GOOGLE_GENAI_API_KEY=<alternative-google-genai-api-key-env>
# GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
# GEMINI_IMAGE_BASE_URL=https://generativelanguage.googleapis.com/v1beta
